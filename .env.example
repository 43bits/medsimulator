# Medsimulator HMS root environment reference
# Copy module-specific values into backend/.env and frontend/.env.local.

# Backend
NODE_ENV=development
PORT=3000
# mysql for current production, postgresql after Render PostgreSQL cutover
DATABASE_PROVIDER=mysql
DATABASE_URL=mysql://user:password@localhost:3306/MedSimulator_core_hms_v2
# Render PostgreSQL example after tested migration:
# DATABASE_URL=postgresql://user:password@host:5432/MedSimulator_core_hms
JWT_SECRET=replace-with-at-least-48-random-characters-in-production
JWT_EXPIRES_IN=1d
FRONTEND_URL=http://localhost:3001
FRONTEND_ORIGINS=http://localhost:3001
PUBLIC_API_BASE_URL=http://localhost:3000

# Security and performance
PASSWORD_MIN_LENGTH=12
AUTH_FAILED_LOGIN_DELAY_MAX_MS=2500
STEP_UP_TTL_SECONDS=300
STEP_UP_ENFORCEMENT_ENABLED=false
REQUEST_TIMEOUT_MS=30000
BODY_LIMIT=4mb
PDF_IMAGE_MAX_BYTES=512000
REDIS_URL=
CACHE_PREFIX=inv_hms
CACHE_DEFAULT_TTL_SECONDS=60
CACHE_DASHBOARD_TTL_SECONDS=30
CACHE_REFERENCE_TTL_SECONDS=300
CACHE_IN_MEMORY_MAX_ITEMS=10000
RATE_LIMIT_TTL_SECONDS=60
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
SEARCH_RATE_LIMIT_MAX=60
DASHBOARD_RATE_LIMIT_MAX=120
PDF_RATE_LIMIT_MAX=20
MPESA_RATE_LIMIT_MAX=5
PUBLIC_VERIFY_RATE_LIMIT_MAX=30

# Queue and workers
QUEUE_ENABLED=true
QUEUE_CONCURRENCY=5
QUEUE_PREFIX=inv_hms
WORKER_MODE=false

# M-Pesa / Daraja
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=174379
MPESA_CALLBACK_URL=https://your-backend.example.com/billing/payments/mpesa/callback
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_PROMPT_LOCK_SECONDS=90
MPESA_MAX_CONCURRENT_PROMPTS=20
MPESA_REQUEST_TIMEOUT_MS=15000
MPESA_STATUS_CACHE_SECONDS=10

# AI and feature flags
AI_ENABLED=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
PATIENT_PORTAL_ENABLED=false
SMS_ENABLED=false
WHATSAPP_ENABLED=false
SHA_ENABLED=true
DATA_WAREHOUSE_ENABLED=false
CLINICAL_DECISION_SUPPORT_ENABLED=true
MOBILE_OPTIMIZED_VIEWS_ENABLED=true

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Render production examples:
# NEXT_PUBLIC_API_BASE_URL=https://your-render-backend.onrender.com
# NEXT_PUBLIC_APP_URL=https://your-render-frontend.onrender.com
